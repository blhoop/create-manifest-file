{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CTM-Infrastructure/workflow-agentic-infra-builder/manifest-schema.json",
  "title": "CTM Spoke Infrastructure Manifest",
  "description": "Machine-readable source of truth for a spoke's Azure infrastructure. Consumed by workflow-agentic-infra-builder to generate Terraform HCL and deploy landing zones.",
  "type": "object",
  "required": ["schema_version", "spoke", "ctm_properties", "environments", "tags", "network"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1",
      "description": "Manifest schema version. Must be '1' for this schema."
    },

    "spoke": {
      "type": "object",
      "description": "Spoke identity and ownership metadata.",
      "required": ["name", "subscription", "owner", "description"],
      "additionalProperties": false,
      "properties": {
        "name":         { "type": "string", "pattern": "^[a-z][a-z0-9-]+$", "description": "Spoke short name (used in resource naming). e.g. ctm-intelligence" },
        "subscription": { "type": "string", "description": "Azure subscription name or '[TBD]'" },
        "owner":        { "type": "string", "description": "Owning team name" },
        "description":  { "type": "string", "maxLength": 500, "description": "1-2 sentence purpose statement" },
        "sku_mode":             { "type": "string", "enum": ["premium", "economy"], "default": "premium", "description": "SKU mode: premium (default) = smallest prod-capable SKUs, economy = cheapest viable for dev/lab." },
        "management_group_id":  { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$", "description": "Management group ID to place the subscription under. If omitted, subscription stays in tenant root." },
        "new_subscription":     { "type": "boolean", "default": true, "description": "When true, creates a new subscription via the sub repo. When false, adopts an existing subscription." },
        "sub_repo":             { "type": "string", "pattern": "^[a-z][a-z0-9-]+$", "description": "GitHub repo name for subscription-level resources (SPN, groups, RBAC). Derived as ctm-sub-{name}-{env} if omitted." },
        "infra_repo":           { "type": "string", "pattern": "^[a-z][a-z0-9-]+-infra$", "description": "GitHub repo name for spoke infrastructure. Derived as {name}-infra if omitted." }
      }
    },

    "ctm_properties": {
      "type": "object",
      "description": "Shared CTM naming properties applied to all resources in this spoke.",
      "required": ["product"],
      "additionalProperties": false,
      "properties": {
        "product": { "type": "string", "pattern": "^[a-z][a-z0-9]+$", "description": "Product code used in CTM naming convention. e.g. ctmi, gprof, lb" }
      }
    },

    "environments": {
      "type": "object",
      "description": "Environment definitions. Keys are environment names (dev, uat, prod, etc.).",
      "minProperties": 1,
      "patternProperties": {
        "^(dev|test|uat|preprod|prod|lab)$": {
          "$ref": "#/$defs/environment"
        }
      },
      "additionalProperties": false
    },

    "tags": {
      "type": "object",
      "description": "Governance tags applied to all resources via terraform-azurerm-tags. Values may contain '[TBD]' placeholders.",
      "properties": {
        "owner":        { "type": "string" },
        "cost_center":  { "type": "string" },
        "project":      { "type": "string" },
        "data_classification": { "type": "string", "enum": ["public", "internal", "confidential", "restricted", "[TBD]"] }
      },
      "additionalProperties": { "type": "string" }
    },

    "network": {
      "$ref": "#/$defs/network_block"
    },

    "compute": {
      "$ref": "#/$defs/compute_block"
    },

    "data": {
      "$ref": "#/$defs/data_block"
    },

    "security": {
      "$ref": "#/$defs/security_block"
    },

    "observability": {
      "$ref": "#/$defs/observability_block"
    },

    "frontdoor": {
      "$ref": "#/$defs/frontdoor_block"
    },

    "ai": {
      "$ref": "#/$defs/ai_block"
    },

    "app_configuration": {
      "$ref": "#/$defs/app_configuration_block"
    },

    "platform": {
      "$ref": "#/$defs/platform_block"
    },

    "dependencies": {
      "type": "array",
      "description": "Informational cross-spoke and external dependencies.",
      "items": { "$ref": "#/$defs/dependency" }
    },

    "blockers": {
      "type": "array",
      "description": "Known blockers, red flags, and gaps. Workflow rejects deployment if any severity=HIGH remain OPEN.",
      "items": { "$ref": "#/$defs/blocker" }
    }
  },

  "$defs": {

    "tbd_string": {
      "description": "A string that may be '[TBD]' — workflow validates and blocks deployment if any remain.",
      "type": "string"
    },

    "module_ref": {
      "type": "string",
      "pattern": "^terraform-azurerm-[a-z0-9-]+$",
      "description": "CTM module name from the private registry. e.g. terraform-azurerm-linux-web-app"
    },

    "resource_ref": {
      "type": "string",
      "pattern": "^\\$ref:[a-z][a-z0-9_-]+\\.[a-z_]+$",
      "description": "Cross-resource reference resolved to module.<id>.<attr> during HCL generation. e.g. $ref:rg.resource_id"
    },

    "environment": {
      "type": "object",
      "description": "Per-environment configuration.",
      "required": ["location"],
      "additionalProperties": false,
      "properties": {
        "location": {
          "type": "string",
          "enum": ["australiaeast", "eastus", "eastus2", "northcentralus", "southeastasia", "uksouth", "westus3"],
          "description": "Azure region for this environment."
        },
        "location_secondary": {
          "type": "string",
          "enum": ["australiaeast", "eastus", "eastus2", "northcentralus", "southeastasia", "uksouth", "westus3"],
          "description": "Secondary Azure region for dual-region deployments."
        },
        "overrides": {
          "type": "object",
          "description": "Deep-merged onto resource defaults for this environment. Keys match resource IDs, values are partial resource configs.",
          "additionalProperties": true
        }
      }
    },

    "network_block": {
      "type": "object",
      "description": "Networking configuration for the spoke.",
      "additionalProperties": false,
      "properties": {
        "vnets": {
          "type": "array",
          "items": { "$ref": "#/$defs/vnet" }
        },
        "subnets": {
          "type": "array",
          "items": { "$ref": "#/$defs/subnet" }
        },
        "nsgs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nsg" }
        },
        "private_endpoints": {
          "type": "array",
          "items": { "$ref": "#/$defs/private_endpoint" }
        },
        "dns_zones": {
          "type": "array",
          "items": { "$ref": "#/$defs/dns_zone" }
        },
        "nat_gateway": {
          "$ref": "#/$defs/nat_gateway"
        },
        "vnet_peerings": {
          "type": "array",
          "description": "Intra-spoke VNet peerings (e.g. cross-region).",
          "items": { "$ref": "#/$defs/vnet_peering" }
        },
        "cross_spoke_peerings": {
          "type": "array",
          "description": "Cross-spoke VNet peerings using native azurerm resources (conditional on remote VNet vars).",
          "items": { "$ref": "#/$defs/cross_spoke_peering" }
        },
        "dns_zone_cross_spoke_links": {
          "type": "array",
          "description": "Cross-spoke DNS zone VNet links (conditional on target VNet vars).",
          "items": { "$ref": "#/$defs/dns_zone_cross_spoke_link" }
        }
      }
    },

    "vnet": {
      "type": "object",
      "required": ["id", "cidr", "dns_servers", "peering"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "description": "Logical ID used in $ref references and HCL module name." },
        "cidr":        { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+/[0-9]+$", "description": "VNet CIDR block." },
        "dns_servers": { "oneOf": [{ "type": "array", "items": { "type": "string" } }, { "const": "hub-inherited" }] },
        "peering":     { "type": "string", "description": "Hub VNet peering target. e.g. hub-network-vnet" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" }
      }
    },

    "subnet": {
      "type": "object",
      "required": ["id", "vnet_id", "cidr", "purpose"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "vnet_id":     { "type": "string", "description": "Logical ID of parent VNet." },
        "cidr":        { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+/[0-9]+$" },
        "delegation":  { "type": ["string", "null"], "description": "Azure delegation. e.g. Microsoft.Web/serverFarms, Microsoft.App/environments" },
        "purpose":     { "type": "string" }
      }
    },

    "nsg": {
      "type": "object",
      "required": ["id", "subnet_id", "rules"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "subnet_id": { "type": "string", "description": "Logical ID of the subnet this NSG attaches to." },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "priority", "direction", "access", "protocol", "destination_port_range"],
            "additionalProperties": false,
            "properties": {
              "name":                    { "type": "string" },
              "priority":                { "type": "integer", "minimum": 100, "maximum": 4096 },
              "direction":               { "type": "string", "enum": ["Inbound", "Outbound"] },
              "access":                  { "type": "string", "enum": ["Allow", "Deny"] },
              "protocol":                { "type": "string", "enum": ["Tcp", "Udp", "*"] },
              "source_address_prefix":   { "type": "string" },
              "source_address_prefixes": { "type": "array", "items": { "type": "string" } },
              "destination_port_range":  { "type": "string" },
              "description":             { "type": "string" }
            }
          }
        }
      }
    },

    "private_endpoint": {
      "type": "object",
      "required": ["id", "target_resource_id", "sub_resource", "subnet_id", "dns_zone"],
      "additionalProperties": false,
      "properties": {
        "id":                 { "type": "string" },
        "target_resource_id": { "type": "string", "description": "$ref to the target resource or literal resource ID." },
        "sub_resource":       { "type": "string", "description": "Sub-resource type. e.g. postgresqlServer, vault, registry" },
        "subnet_id":          { "type": "string", "description": "Logical ID of the PE subnet." },
        "dns_zone":           { "type": "string", "description": "Private DNS zone name." }
      }
    },

    "dns_zone": {
      "type": "object",
      "required": ["id", "zone_name"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "zone_name": { "type": "string", "description": "Private DNS zone FQDN. e.g. privatelink.postgres.database.azure.com" },
        "linked_vnets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "VNet IDs to link this zone to."
        }
      }
    },

    "nat_gateway": {
      "type": "object",
      "required": ["id", "subnet_ids"],
      "additionalProperties": false,
      "properties": {
        "id":         { "type": "string" },
        "subsystem":  { "type": "string" },
        "subnet_ids": { "type": "array", "items": { "type": "string" }, "description": "Logical IDs of subnets to associate." },
        "idle_timeout_minutes": { "type": "integer", "default": 4, "minimum": 4, "maximum": 120 },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" }
      }
    },

    "vnet_peering": {
      "type": "object",
      "required": ["id", "name", "vnet_id", "remote_vnet_id"],
      "additionalProperties": false,
      "properties": {
        "id":                     { "type": "string" },
        "name":                   { "type": "string" },
        "vnet_id":                { "type": "string", "description": "Logical ID of the local VNet." },
        "remote_vnet_id":         { "type": "string", "description": "Logical ID of the remote VNet." },
        "allow_forwarded_traffic": { "type": "boolean", "default": false }
      }
    },

    "cross_spoke_peering": {
      "type": "object",
      "required": ["id", "name", "vnet_id", "remote_vnet_var"],
      "additionalProperties": false,
      "properties": {
        "id":                     { "type": "string" },
        "name":                   { "type": "string" },
        "vnet_id":                { "type": "string", "description": "Logical ID of the local VNet." },
        "remote_vnet_var":        { "type": "string", "description": "Variable name for remote VNet ID." },
        "allow_forwarded_traffic": { "type": "boolean", "default": false },
        "conditional":            { "type": "boolean", "default": false }
      }
    },

    "dns_zone_cross_spoke_link": {
      "type": "object",
      "required": ["dns_zone_id", "target_vnet_var", "link_name"],
      "additionalProperties": false,
      "properties": {
        "dns_zone_id":    { "type": "string", "description": "Logical ID of the DNS zone." },
        "target_vnet_var": { "type": "string", "description": "Variable name for the target VNet ID." },
        "link_name":      { "type": "string" },
        "conditional":    { "type": "boolean", "default": false }
      }
    },

    "compute_block": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "app_service_plans": {
          "type": "array",
          "items": { "$ref": "#/$defs/app_service_plan" }
        },
        "web_apps": {
          "type": "array",
          "items": { "$ref": "#/$defs/web_app" }
        },
        "function_apps": {
          "type": "array",
          "items": { "$ref": "#/$defs/function_app" }
        },
        "aks_clusters": {
          "type": "array",
          "items": { "$ref": "#/$defs/aks_cluster" }
        },
        "container_app_environments": {
          "type": "array",
          "items": { "$ref": "#/$defs/container_app_environment" }
        },
        "container_apps": {
          "type": "array",
          "items": { "$ref": "#/$defs/container_app" }
        },
        "virtual_machines": {
          "type": "array",
          "items": { "$ref": "#/$defs/virtual_machine" }
        },
        "apim": {
          "$ref": "#/$defs/apim"
        },
        "static_sites": {
          "type": "array",
          "items": { "$ref": "#/$defs/static_site" }
        }
      }
    },

    "app_service_plan": {
      "type": "object",
      "required": ["id", "subsystem", "sku", "os_type", "module"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "subsystem": { "type": "string" },
        "sku":       { "type": "string", "description": "SKU name. e.g. P1v3, B1, S1, EP1" },
        "os_type":   { "type": "string", "enum": ["Linux", "Windows"] },
        "module":    { "$ref": "#/$defs/module_ref" },
        "zone_balancing_enabled": { "type": "boolean", "default": false },
        "worker_count": { "type": "integer", "minimum": 1 },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":   { "type": "boolean", "default": true }
      }
    },

    "web_app": {
      "type": "object",
      "required": ["id", "subsystem", "asp_id", "module"],
      "additionalProperties": false,
      "properties": {
        "id":           { "type": "string" },
        "subsystem":    { "type": "string" },
        "asp_id":       { "type": "string", "description": "Logical ID of the App Service Plan." },
        "module":       { "$ref": "#/$defs/module_ref" },
        "docker":       { "type": "boolean", "default": false },
        "slots":        { "type": "array", "items": { "type": "string" }, "description": "Slot names. e.g. [staging, prestaging]" },
        "port":         { "type": "integer", "description": "Container port. e.g. 8080" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "vnet_integration_subnet_id": { "type": "string", "description": "Logical ID of the subnet for VNet integration." },
        "app_settings": { "type": "object", "additionalProperties": { "type": "string" } },
        "enabled":      { "type": "boolean", "default": true }
      }
    },

    "function_app": {
      "type": "object",
      "required": ["id", "subsystem", "runtime", "module"],
      "additionalProperties": false,
      "properties": {
        "id":           { "type": "string" },
        "subsystem":    { "type": "string" },
        "asp_id":       { "type": ["string", "null"], "description": "Logical ID of ASP. null = Consumption plan." },
        "runtime":      { "type": "string", "enum": ["dotnet-isolated", "python", "node", "java", "powershell", "custom"] },
        "runtime_version": { "type": "string" },
        "module":       { "$ref": "#/$defs/module_ref" },
        "trigger":      { "type": "string", "enum": ["HTTP", "Timer", "ServiceBus", "Queue", "Blob", "CosmosDB", "EventHub", "EventGrid"] },
        "purpose":      { "type": "string" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "slots":        { "type": "array", "items": { "type": "string" }, "description": "Deployment slot names for blue/green deployments." },
        "vnet_integration_subnet_id": { "type": "string", "description": "Logical ID of the subnet for VNet integration." },
        "storage_account_id": { "type": "string", "description": "Logical ID of dedicated storage account for function app backing storage." },
        "docker":       { "type": "boolean", "default": false },
        "enabled":      { "type": "boolean", "default": true }
      }
    },

    "aks_cluster": {
      "type": "object",
      "required": ["id", "subsystem", "kubernetes_version", "module"],
      "additionalProperties": false,
      "properties": {
        "id":                  { "type": "string" },
        "subsystem":           { "type": "string" },
        "kubernetes_version":  { "type": "string" },
        "module":              { "$ref": "#/$defs/module_ref" },
        "default_node_pool": {
          "type": "object",
          "required": ["vm_size", "min_count", "max_count"],
          "additionalProperties": false,
          "properties": {
            "vm_size":   { "type": "string" },
            "min_count": { "type": "integer", "minimum": 1 },
            "max_count": { "type": "integer", "minimum": 1 },
            "os_disk_size_gb": { "type": "integer" },
            "zones":     { "type": "array", "items": { "type": "string" } }
          }
        },
        "additional_node_pools": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "vm_size", "min_count", "max_count"],
            "additionalProperties": false,
            "properties": {
              "name":      { "type": "string" },
              "vm_size":   { "type": "string" },
              "min_count": { "type": "integer" },
              "max_count": { "type": "integer" },
              "os_type":   { "type": "string", "enum": ["Linux", "Windows"] },
              "mode":      { "type": "string", "enum": ["System", "User"] }
            }
          }
        },
        "subnet_id":        { "type": "string" },
        "private_cluster":  { "type": "boolean", "default": false },
        "instance_number":  { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":          { "type": "boolean", "default": true }
      }
    },

    "container_app_environment": {
      "type": "object",
      "required": ["id", "subsystem", "subnet_id", "module"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "subsystem":   { "type": "string" },
        "subnet_id":   { "type": "string" },
        "module":      { "$ref": "#/$defs/module_ref" },
        "internal_only": { "type": "boolean", "default": true },
        "storage_registrations": {
          "type": "array",
          "description": "Azure Files shares registered with the CAE for volume mounting by Container Apps.",
          "items": {
            "type": "object",
            "required": ["name", "storage_account_id", "share_name"],
            "additionalProperties": false,
            "properties": {
              "name":               { "type": "string", "description": "Logical name used to reference this storage from Container App volumes." },
              "storage_account_id": { "type": "string", "description": "Logical ID of the storage account in the manifest." },
              "share_name":         { "type": "string", "description": "Name of the Azure Files share." },
              "access_mode":        { "type": "string", "enum": ["ReadOnly", "ReadWrite"], "default": "ReadWrite" }
            }
          }
        },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":     { "type": "boolean", "default": true }
      }
    },

    "container_app": {
      "type": "object",
      "required": ["id", "subsystem", "cae_id", "image", "module"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "subsystem":   { "type": "string" },
        "cae_id":      { "type": "string", "description": "Logical ID of the Container App Environment." },
        "image":       { "type": "string" },
        "module":      { "$ref": "#/$defs/module_ref" },
        "purpose":     { "type": "string" },
        "min_replicas": { "type": "integer", "minimum": 0 },
        "max_replicas": { "type": "integer", "minimum": 1 },
        "target_port": { "type": "integer" },
        "persistent_volumes": {
          "type": "array",
          "description": "Persistent volumes mounted from CAE-registered Azure Files shares.",
          "items": {
            "type": "object",
            "required": ["name", "cae_storage_name", "mount_path"],
            "additionalProperties": false,
            "properties": {
              "name":             { "type": "string", "description": "Volume name within the Container App template." },
              "cae_storage_name": { "type": "string", "description": "Name of the CAE storage registration to mount." },
              "mount_path":       { "type": "string", "description": "Absolute path inside the container where the volume is mounted." }
            }
          }
        },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":     { "type": "boolean", "default": true }
      }
    },

    "virtual_machine": {
      "type": "object",
      "required": ["id", "subsystem", "role", "vm_size", "os_type", "module"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "subsystem":   { "type": "string" },
        "role":        { "type": "string", "description": "VM role. e.g. web-dmz, web-internal, app-server" },
        "vm_size":     { "type": "string", "description": "Azure VM size. e.g. Standard_D4s_v5" },
        "os_type":     { "type": "string", "enum": ["Windows", "Linux"] },
        "module":      { "$ref": "#/$defs/module_ref" },
        "subnet_id":   { "type": "string" },
        "purpose":     { "type": "string" },
        "count":       { "type": "integer", "minimum": 1, "default": 1 },
        "zone":        { "type": "string", "enum": ["1", "2", "3"] },
        "public_ip":   { "type": "boolean", "default": false, "description": "Attach a Standard SKU public IP to the VM NIC" },
        "load_balanced": { "type": "boolean", "default": false },
        "enabled":     { "type": "boolean", "default": true }
      }
    },

    "managed_identities_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "system_assigned": { "type": "boolean", "default": false },
        "user_assigned_resource_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "apim": {
      "type": "object",
      "required": ["id", "subsystem", "module", "sku_name"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "subsystem": { "type": "string" },
        "module":    { "const": "terraform-azurerm-api-management" },
        "sku_name":  { "type": "string" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "virtual_network_type": { "type": "string", "enum": ["None", "External", "Internal"] },
        "public_network_access_enabled": { "type": "boolean" },
        "subnet_id": { "type": "string" },
        "managed_identities": { "$ref": "#/$defs/managed_identities_config" },
        "enabled":   { "type": "boolean", "default": true }
      }
    },

    "data_block": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "databases": {
          "type": "array",
          "items": { "$ref": "#/$defs/database" }
        },
        "caching": {
          "type": "array",
          "items": { "$ref": "#/$defs/cache" }
        },
        "messaging": {
          "type": "array",
          "items": { "$ref": "#/$defs/messaging" }
        },
        "storage_accounts": {
          "type": "array",
          "items": { "$ref": "#/$defs/storage_account" }
        },
        "factories": {
          "type": "array",
          "items": { "$ref": "#/$defs/data_factory" }
        },
        "search": {
          "type": "array",
          "items": { "$ref": "#/$defs/search_service" }
        }
      }
    },

    "database": {
      "type": "object",
      "required": ["id", "subsystem", "type", "sku", "module"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "subsystem":   { "type": "string" },
        "type":        { "type": "string", "enum": ["postgresql_flexible_server", "mssql_server", "mssql_managed_instance", "mysql_flexible_server", "cosmos_account"] },
        "sku":         { "type": "string" },
        "module":      { "$ref": "#/$defs/module_ref" },
        "extensions":  { "type": "array", "items": { "type": "string" }, "description": "Database extensions. e.g. uuid-ossp, pgvector" },
        "pgbouncer_enabled": { "type": "boolean", "default": false, "description": "Enable PgBouncer connection pooling (PG Flexible Server only)." },
        "ha":          { "type": "string", "enum": ["none", "zone-redundant", "same-zone"], "default": "none" },
        "backup":      { "type": "string", "enum": ["local", "geo-redundant"], "default": "local" },
        "databases":   { "type": "array", "items": { "type": "string" }, "description": "Database names to create within the server." },
        "version":     { "type": "string", "description": "Database engine version. e.g. 16, 18" },
        "zone":        { "type": "string", "enum": ["1", "2", "3"], "description": "Availability zone for the database server." },
        "public_network_access": { "type": "boolean", "default": false, "description": "Enable public network access. Defaults to false (private endpoints only)." },
        "capacity_mode": { "type": "string", "enum": ["provisioned", "serverless"], "description": "Cosmos DB capacity mode." },
        "purpose":     { "type": "string" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":     { "type": "boolean", "default": true }
      }
    },

    "cache": {
      "type": "object",
      "required": ["id", "subsystem", "sku", "module"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "subsystem": { "type": "string" },
        "sku":       { "type": "string" },
        "module":    { "$ref": "#/$defs/module_ref" },
        "purpose":   { "type": "string" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":   { "type": "boolean", "default": true }
      }
    },

    "messaging": {
      "type": "object",
      "required": ["id", "subsystem", "type", "module"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "subsystem": { "type": "string" },
        "type":      { "type": "string", "enum": ["service_bus", "event_hub", "rabbitmq_container_app", "storage_queue"] },
        "module":    { "$ref": "#/$defs/module_ref" },
        "sku":       { "type": "string" },
        "topics":    { "type": "array", "items": { "type": "string" } },
        "queues":    { "type": "array", "items": { "type": "string" } },
        "purpose":   { "type": "string" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":   { "type": "boolean", "default": true }
      }
    },

    "storage_account": {
      "type": "object",
      "required": ["id", "subsystem", "module"],
      "additionalProperties": false,
      "properties": {
        "id":         { "type": "string" },
        "subsystem":  { "type": "string" },
        "module":     { "type": "string" },
        "sku":        { "type": "string", "enum": ["Standard_LRS", "Standard_GRS", "Standard_ZRS", "Standard_GZRS", "Premium_LRS", "Premium_ZRS"] },
        "containers": { "type": "array", "items": { "type": "string" } },
        "tables":     { "type": "array", "items": { "type": "string" } },
        "queues":     { "type": "array", "items": { "type": "string" } },
        "file_shares": { "type": "array", "items": { "type": "string" } },
        "shared_access_key_enabled": { "type": "boolean", "default": false, "description": "Enable shared access key on the storage account. Required for CAE storage mounts and function app backing storage." },
        "purpose":    { "type": "string" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":    { "type": "boolean", "default": true }
      }
    },

    "static_site": {
      "type": "object",
      "required": ["id", "subsystem", "module"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "subsystem": { "type": "string" },
        "module":    { "$ref": "#/$defs/module_ref" },
        "sku":       { "type": "string" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "location_override": { "type": "string", "description": "Override location for region-restricted resources" },
        "enabled":   { "type": "boolean", "default": true }
      }
    },

    "data_factory": {
      "type": "object",
      "required": ["id", "subsystem", "module"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "subsystem": { "type": "string" },
        "module":    { "$ref": "#/$defs/module_ref" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":   { "type": "boolean", "default": true }
      }
    },

    "search_service": {
      "type": "object",
      "required": ["id", "subsystem", "module"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "subsystem": { "type": "string" },
        "module":    { "$ref": "#/$defs/module_ref" },
        "sku":       { "type": "string" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":   { "type": "boolean", "default": true }
      }
    },

    "security_block": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key_vaults": {
          "type": "array",
          "items": { "$ref": "#/$defs/key_vault" }
        },
        "managed_identities": {
          "type": "array",
          "items": { "$ref": "#/$defs/managed_identity" }
        },
        "container_registries": {
          "type": "array",
          "items": { "$ref": "#/$defs/container_registry" }
        }
      }
    },

    "key_vault": {
      "type": "object",
      "required": ["id", "subsystem", "module"],
      "additionalProperties": false,
      "properties": {
        "id":           { "type": "string" },
        "subsystem":    { "type": "string" },
        "module":       { "type": "string" },
        "access_model": { "type": "string", "enum": ["RBAC", "access_policy"], "default": "RBAC" },
        "consumers":    { "type": "array", "items": { "type": "string" }, "description": "Logical IDs of consuming resources." },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "purge_protection_enabled": { "type": "boolean", "description": "Irreversible once enabled. Prevents permanent deletion of the Key Vault." },
        "bypass_naming_convention": { "type": "boolean", "default": false, "description": "Use the name field directly instead of generated naming convention." },
        "name":         { "type": "string", "description": "Custom resource name (only used when bypass_naming_convention is true)." },
        "enabled":      { "type": "boolean", "default": true }
      }
    },

    "managed_identity": {
      "type": "object",
      "required": ["id", "subsystem"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "subsystem":   { "type": "string" },
        "type":        { "type": "string", "enum": ["system_assigned", "user_assigned"] },
        "module":      { "$ref": "#/$defs/module_ref" },
        "assigned_to": { "type": "array", "items": { "type": "string" }, "description": "Logical IDs of resources this identity is assigned to." },
        "access_to":   { "type": "array", "items": { "type": "string" }, "description": "Resources this identity can access. e.g. Key Vault (Secrets Reader)" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":     { "type": "boolean", "default": true }
      }
    },

    "container_registry": {
      "type": "object",
      "required": ["id", "subsystem", "sku", "module"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "subsystem": { "type": "string" },
        "sku":       { "type": "string", "enum": ["Basic", "Standard", "Premium"] },
        "module":    { "$ref": "#/$defs/module_ref" },
        "consumers": { "type": "array", "items": { "type": "string" } },
        "georeplications": { "type": "array", "items": { "type": "string" }, "description": "Azure regions for geo-replication. e.g. [eastus2]" },
        "managed_identities": { "$ref": "#/$defs/managed_identities_config" },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":   { "type": "boolean", "default": true }
      }
    },

    "observability_block": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "log_analytics_workspace": {
          "type": "object",
          "required": ["id", "subsystem", "module"],
          "additionalProperties": false,
          "properties": {
            "id":        { "type": "string" },
            "subsystem": { "type": "string" },
            "module":    { "type": "string" },
            "retention_days": { "type": "integer", "default": 30 },
            "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" }
          }
        },
        "app_insights": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "subsystem", "module"],
            "additionalProperties": false,
            "properties": {
              "id":           { "type": "string" },
              "subsystem":    { "type": "string" },
              "module":       { "$ref": "#/$defs/module_ref" },
              "workspace_id": { "type": "string", "description": "Logical ID of the Log Analytics Workspace." },
              "linked_to":    { "type": "array", "items": { "type": "string" }, "description": "Logical IDs of resources linked to this App Insights." },
              "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" }
            }
          }
        }
      }
    },

    "frontdoor_block": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "object",
          "required": ["id", "subsystem", "sku", "module"],
          "additionalProperties": false,
          "properties": {
            "id":        { "type": "string" },
            "subsystem": { "type": "string" },
            "sku":       { "type": "string", "enum": ["Standard_AzureFrontDoor", "Premium_AzureFrontDoor"] },
            "module":    { "$ref": "#/$defs/module_ref" },
            "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
            "enabled":   { "type": "boolean", "default": true }
          }
        },
        "endpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "subsystem", "module"],
            "additionalProperties": false,
            "properties": {
              "id":        { "type": "string" },
              "subsystem": { "type": "string" },
              "module":    { "$ref": "#/$defs/module_ref" },
              "enabled":   { "type": "boolean", "default": true }
            }
          }
        },
        "origin_groups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "subsystem", "module"],
            "additionalProperties": false,
            "properties": {
              "id":        { "type": "string" },
              "subsystem": { "type": "string" },
              "module":    { "$ref": "#/$defs/module_ref" },
              "health_probe_path": { "type": "string" },
              "enabled":   { "type": "boolean", "default": true }
            }
          }
        },
        "origins": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "subsystem", "origin_group_id", "host_name", "module"],
            "additionalProperties": false,
            "properties": {
              "id":              { "type": "string" },
              "subsystem":       { "type": "string" },
              "origin_group_id": { "type": "string" },
              "host_name":       { "type": "string", "description": "$ref or literal hostname." },
              "module":          { "$ref": "#/$defs/module_ref" },
              "enabled":         { "type": "boolean", "default": true }
            }
          }
        },
        "routes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "subsystem", "endpoint_id", "origin_group_id", "patterns_to_match", "module"],
            "additionalProperties": false,
            "properties": {
              "id":               { "type": "string" },
              "subsystem":        { "type": "string" },
              "endpoint_id":      { "type": "string" },
              "origin_group_id":  { "type": "string" },
              "patterns_to_match": { "type": "array", "items": { "type": "string" } },
              "supported_protocols": { "type": "array", "items": { "type": "string", "enum": ["Http", "Https"] } },
              "module":           { "$ref": "#/$defs/module_ref" },
              "enabled":          { "type": "boolean", "default": true }
            }
          }
        },
        "firewall_policy": {
          "type": "object",
          "required": ["id", "subsystem", "module", "sku", "mode"],
          "additionalProperties": false,
          "properties": {
            "id":        { "type": "string" },
            "subsystem": { "type": "string" },
            "module":    { "$ref": "#/$defs/module_ref" },
            "sku":       { "type": "string", "enum": ["Standard_AzureFrontDoor", "Premium_AzureFrontDoor"] },
            "mode":      { "type": "string", "enum": ["Detection", "Prevention"] },
            "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" }
          }
        },
        "security_policy": {
          "type": "object",
          "required": ["id", "module", "firewall_policy_id", "endpoint_ids"],
          "additionalProperties": false,
          "properties": {
            "id":                  { "type": "string" },
            "module":              { "$ref": "#/$defs/module_ref" },
            "firewall_policy_id":  { "type": "string" },
            "endpoint_ids":        { "type": "array", "items": { "type": "string" } }
          }
        },
        "custom_domains": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "module", "host_name"],
            "additionalProperties": false,
            "properties": {
              "id":        { "type": "string" },
              "module":    { "$ref": "#/$defs/module_ref" },
              "host_name": { "type": "string" }
            }
          }
        }
      }
    },

    "ai_block": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "foundry": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "subsystem", "module", "models"],
            "additionalProperties": false,
            "properties": {
              "id":        { "type": "string" },
              "subsystem": { "type": "string" },
              "module":    { "$ref": "#/$defs/module_ref" },
              "purpose":   { "type": "string" },
              "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
              "storage_account_id": { "type": "string" },
              "models": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "version"],
                  "additionalProperties": false,
                  "properties": {
                    "name":    { "type": "string" },
                    "version": { "type": "string" }
                  }
                }
              },
              "enabled": { "type": "boolean", "default": true }
            }
          }
        },
        "external_apis": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["provider", "endpoint", "auth_method", "purpose"],
            "additionalProperties": false,
            "properties": {
              "provider":    { "type": "string" },
              "endpoint":    { "type": "string" },
              "auth_method": { "type": "string" },
              "purpose":     { "type": "string" }
            }
          }
        }
      }
    },

    "app_configuration_block": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "subsystem", "module"],
        "additionalProperties": false,
        "properties": {
          "id":        { "type": "string" },
          "subsystem": { "type": "string" },
          "module":    { "type": "string" },
          "purpose":   { "type": "string" },
          "consumers": { "type": "array", "items": { "type": "string" } },
          "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
          "enabled":   { "type": "boolean", "default": true }
        }
      }
    },

    "platform_block": {
      "type": "object",
      "description": "Platform-level resources including azapi provider resources and service bus namespaces.",
      "additionalProperties": false,
      "properties": {
        "azapi_resources": {
          "type": "array",
          "items": { "$ref": "#/$defs/azapi_resource" }
        },
        "servicebus": {
          "type": "array",
          "items": { "$ref": "#/$defs/servicebus_namespace" }
        }
      }
    },

    "servicebus_namespace": {
      "type": "object",
      "required": ["id", "subsystem", "module"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "subsystem": { "type": "string" },
        "module":    { "type": "string" },
        "sku":       { "type": "string", "enum": ["Basic", "Standard", "Premium"] },
        "instance_number": { "type": "string", "pattern": "^[0-9]{3}$" },
        "enabled":   { "type": "boolean", "default": true }
      }
    },

    "azapi_resource": {
      "type": "object",
      "description": "An Azure resource managed via the azapi provider for resource types not covered by azurerm.",
      "required": ["id", "type", "api_version", "properties"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "description": "Logical ID used in HCL resource name." },
        "type":        { "type": "string", "description": "Azure resource type. e.g. GitHub.Network/networkSettings" },
        "api_version": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}(-preview)?$", "description": "ARM API version. e.g. 2024-04-02" },
        "name":        { "type": "string", "description": "Azure resource name. If omitted, uses the id." },
        "parent_id":   { "type": "string", "description": "$ref to parent resource ID (typically resource group). Defaults to module.rg.resource_id" },
        "properties":  { "type": "object", "additionalProperties": true, "description": "Resource-specific properties. $ref values are resolved to module references." }
      }
    },

    "dependency": {
      "type": "object",
      "required": ["name", "type", "direction"],
      "additionalProperties": false,
      "properties": {
        "name":      { "type": "string" },
        "type":      { "type": "string", "enum": ["vnet_peering", "cross_spoke", "https_egress", "vpn", "service_bus", "database"] },
        "direction": { "type": "string", "enum": ["inbound", "outbound", "bidirectional"] },
        "notes":     { "type": "string" }
      }
    },

    "blocker": {
      "type": "object",
      "required": ["id", "issue", "severity", "status"],
      "additionalProperties": false,
      "properties": {
        "id":         { "type": "integer" },
        "issue":      { "type": "string" },
        "severity":   { "type": "string", "enum": ["HIGH", "MED", "LOW"] },
        "status":     { "type": "string", "enum": ["OPEN", "RESOLVED"] },
        "resolution": { "type": "string" }
      }
    }
  }
}
